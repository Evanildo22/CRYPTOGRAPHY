# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# 32-byte hex HMAC key for audit log tamper detection
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
AUDIT_LOG_KEY=replace_with_64_hex_chars

# Flask session signing key
FLASK_SECRET_KEY=replace_with_64_hex_chars

# Set to 0 in production (FLASK_ENV was removed in Flask 3.0)
FLASK_DEBUG=0
